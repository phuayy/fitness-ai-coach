# Backend
APP_ENV=production
APP_VERSION=1.1.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
POSE_MODEL_PATH=/app/models/pose_landmarker_full.task
INFERENCE_FPS=15
MAX_SESSIONS=10
SESSION_IDLE_TIMEOUT_SECONDS=300

# Optional TURN for public testing
TURN_ENABLED=false
TURN_REALM=fitness-ai-coach
TURN_URL=turn:turn.example.com:3478?transport=udp
TURN_SECRET=replace-with-a-long-random-secret
TURN_TTL_SECONDS=3600

# Frontend build-time variables
VITE_API_HTTP_URL=http://127.0.0.1:8000
VITE_API_WS_URL=ws://127.0.0.1:8000
